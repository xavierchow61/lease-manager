# ── Database (Supabase PostgreSQL) ──────────────────────────────────
# Supabase → Project Settings → Database → Connection string.
# DATABASE_URL = the POOLED connection (Transaction mode, port 6543) + ?pgbouncer=true
# DIRECT_URL   = the DIRECT connection (Session mode, port 5432) — used for migrations.
DATABASE_URL="postgresql://postgres.xxxxxxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres"

# ── Session ─────────────────────────────────────────────────────────
# A long random string (32+ chars). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET="change-me-to-a-long-random-string-min-32-chars"

# ── Optional integrations (leave blank to run in local/log mode) ────
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="物業管理系統 <noreply@example.com>"

STRIPE_SECRET_KEY=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_MAX=""
