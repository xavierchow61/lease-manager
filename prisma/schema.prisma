// Prisma schema for the Lease / Property Management system.
// Faithful port of the original Google Sheets data model, with real
// relational columns, hashed passwords and proper types.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (PgBouncer, port 6543) used by the app at runtime.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) used by Prisma for migrations / db push.
  directUrl = env("DIRECT_URL")
}

// 系統帳號 — login accounts for both owners (admin) and tenants.
model Account {
  id                 String   @id @default(cuid())
  email              String   @unique
  passwordHash       String
  name               String   @default("")
  role               String   @default("admin") // "admin" | "tenant"
  tier               String   @default("Free")  // "Free" | "Pro" | "Max" (owners only)
  currency           String   @default("HK$")
  ownerId            String?  // for tenant accounts: the owning admin's Account.id
  linkedTenantId     String?  // for tenant accounts: the business tenant code
  mustChangePassword Boolean  @default(false)
  note               String   @default("")
  createdAt          DateTime @default(now())

  @@index([ownerId])
  @@index([role])
}

// 單位資料 — a rentable unit, optionally occupied by a tenant.
model Unit {
  id              String   @id @default(cuid())
  ownerId         String   // Account.id of the owning admin
  status          String   @default("空置中") // 出租中 | 空置中 | 維修中 | 自住
  tenantCode      String   @default("") // 租客ID — business code, blank when vacant
  tenantName      String   @default("")
  address         String   @default("")
  email           String   @default("")
  monthlyRent     Float    @default(0)
  managementFee   Float    @default(0)
  deposit         Float    @default(0)
  leaseEndDate    String   @default("") // YYYY-MM-DD
  contractFileUrl String   @default("")
  memo            String   @default("") // 待辦事項
  waterRate       Float    @default(0)
  electricRate    Float    @default(0)
  waterUsage      Float    @default(0)
  electricUsage   Float    @default(0)
  waterReading    Float    @default(0) // 上期水錶讀數
  electricReading Float    @default(0) // 上期電錶讀數
  createdAt       DateTime @default(now())

  @@index([ownerId])
  @@index([tenantCode])
}

// 維修記錄
model Repair {
  id          String   @id @default(cuid())
  ownerId     String
  tenantCode  String   @default("")
  applyDate   String   @default("")
  description String   @default("")
  photoUrl    String   @default("")
  status      String   @default("處理中") // 處理中 | 已安排 | 完成
  ownerReply  String   @default("")
  createdAt   DateTime @default(now())

  @@index([ownerId])
  @@index([tenantCode])
}

// 繳費紀錄 — bills, receipts, prepayments, deposit/termination docs.
model Payment {
  id            String   @id @default(cuid())
  ownerId       String
  tenantCode    String   @default("")
  createdDate   String   @default("")
  period        String   @default("") // 款項期間 YYYY-MM
  docCategory   String   @default("帳單") // 帳單 | 收據 | 預付款 | 預付款抵扣 | 退租收據 | 退租帳單
  title         String   @default("")
  totalAmount   Float    @default(0)
  paidAmount    Float    @default(0)
  receiptDate   String   @default("")
  status        String   @default("未繳費") // 未繳費 | 部分繳費 | 已繳費
  relatedDocId  String   @default("")
  autoGenerated Boolean  @default(false)
  needEmail     Boolean  @default(false)
  currency      String   @default("HK$")
  invoiceNumber String   @default("")
  remark        String   @default("")
  createdAt     DateTime @default(now())

  @@index([ownerId])
  @@index([tenantCode])
  @@index([period])
}

// 財務支出
model Expense {
  id          String   @id @default(cuid())
  ownerId     String
  date        String   @default("")
  category    String   @default("其他") // 支出分類
  item        String   @default("")
  amount      Float    @default(0)
  relatedUnit String   @default("")
  remark      String   @default("")
  createdAt   DateTime @default(now())

  @@index([ownerId])
}

// 入退住清單
model Checklist {
  id         String   @id @default(cuid())
  ownerId    String
  tenantCode String
  type       String // 入住 | 退住
  itemsJson  String   @default("[]")
  savedDate  String   @default("")
  updatedAt  DateTime @updatedAt

  @@unique([ownerId, tenantCode, type])
}

// 歷史租客 — archived tenants kept after move-out.
model ArchivedTenant {
  id            String   @id @default(cuid())
  ownerId       String
  tenantCode    String   @default("")
  tenantName    String   @default("")
  address       String   @default("")
  monthlyRent   Float    @default(0)
  deposit       Float    @default(0)
  moveOutDate   String   @default("")
  depositStatus String   @default("")
  notes         String   @default("")
  archivedAt    DateTime @default(now())

  @@index([ownerId])
}

// 訂閱紀錄
model SubscriptionLog {
  id        String   @id @default(cuid())
  email     String
  plan      String
  status    String
  createdAt DateTime @default(now())
}
